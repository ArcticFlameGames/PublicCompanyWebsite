{
  "permissions": {
    "allow": [
      "Bash(Get-ChildItem *)",
      "Bash(grep -E \"\\\\.\\(json|js|ts|toml|config|md|yml|yaml\\)$\")",
      "Bash(npm outdated *)",
      "Bash(npm view *)",
      "Bash(npm install *)",
      "Bash(npx vite *)",
      "PowerShell(npm list *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
